# Maintainer: antidote1911 <eugenadaken836@outlook.com>
pkgname=nounours-player
pkgver=2.0.6
pkgrel=1
pkgdesc="A simple libmpv-based multimedia player"
arch=('x86_64')
url="https://github.com/Antidote1911/Nounours-Player"
license=('GPL2')
depends=('qt6-base' 'qt6-svg' 'mpv')
makedepends=('cmake' 'ninja' 'qt6-tools')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/Antidote1911/Nounours-Player/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cmake -S "Nounours-Player-${pkgver}/src" \
          -B build \
          -G Ninja \
          -DCMAKE_BUILD_TYPE=Release \
          -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build
}

package() {
    DESTDIR="${pkgdir}" cmake --install build
}
